#!/usr/bin/env bash
set -euo pipefail

name=${1:?usage: dev-unregister <name>}

domain_file="${XDG_CONFIG_HOME:-$HOME/.config}/expose-dev-server/domain"
domain=$(cat "$domain_file" 2>/dev/null) || domain="<unknown>"

conf="/opt/caddy/demo-sites.d/$name.caddy"

if [[ ! -f "$conf" ]]; then
  echo "not registered: $name" >&2; exit 0
fi

rm -f "$conf"

caddy-reload 2>/dev/null

echo "UNREGISTERED: $name.$domain"
